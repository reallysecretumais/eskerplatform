# Esker Stays — environment template. Copy to .env.local and fill in.
# These are the SAME values as the Esker OS CRM (one shared Supabase project).

# Public — safe in the browser. The public site runs on these + RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only master key. Add ONLY when a server action genuinely needs to
# bypass RLS (e.g. creating a website booking). NEVER expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=

# AI concierge (added in the AI build step).
# OPENAI_API_KEY=
# ESKER_AI_MODEL=

# Voice concierge (all OPTIONAL — sensible defaults, reuses OPENAI_API_KEY):
# ESKER_STT_MODEL=gpt-4o-mini-transcribe   # speech-to-text (fallback: whisper-1)
# ESKER_TTS_MODEL=gpt-4o-mini-tts          # text-to-speech
# ESKER_TTS_VOICE=nova                     # spoken voice (alloy, coral, sage, …)
# ESKER_TTS_SPEED=1.3                       # delivery speed

# Guest email (Titan business mailbox). SMTP_PASS is required to actually send;
# without it, emails are skipped (booking still works).
# SMTP_HOST=smtp.titan.email
# SMTP_PORT=465
# SMTP_USER=admin@eskerrentals.com
# SMTP_PASS=
# SMTP_FROM=Esker Rentals <admin@eskerrentals.com>
